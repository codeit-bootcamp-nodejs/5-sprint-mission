{
  "name": "sprint-mission-3",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
    "dev": "export NODE_ENV=development && nodemon --exec ts-node src/app.ts",
    "migrate:dev": "export DATABASE_URL=postgresql://postgres:1234@localhost:5432/test-db && npx prisma migrate dev",
    "migrate:reset": "export DATABASE_URL=postgresql://postgres:1234@localhost:5432/test-db && npx prisma migrate reset",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "type:check": "tsc --noEmit",
    "test:service": "export NODE_ENV=test && jest src/test/jest/service --runInBand",
    "build": "npx tsc",
    "prod": "npx prisma migrate deploy && node ./dist/app.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",

    "multer": "^2.0.2",
    "multer-s3": "^3.0.1",
    "pm2": "^6.0.14",
    "prisma": "^6.15.0",
    "redis": "^5.10.0",
    "socket.io": "^4.8.3",
    "supertest": "^7.1.4",
    "uuid": "^13.0.0",
    "ws": "^8.18.3",
    "zod": "^4.1.12"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },

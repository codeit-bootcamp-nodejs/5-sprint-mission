{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "rootDir": "./src/sprint-mission5",
    "outDir": "./dist/sprint-mission5",
    "module": "commonjs",
    "target": "es6",
    "esModuleInterop": true,      
    "moduleResolution": "node",
    "sourceMap": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleDetection": "force",
    "typeRoots": [],
  },
  "include": ["./src/sprint-mission5"],
  "exclude": ["node_modules"]
}

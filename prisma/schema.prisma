// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String    @id @default(uuid())
  name        String
  description String
  price       Int
  tags        String[]
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comments    Comment[] @relation("ProductComment")
}

model Article {
  id        String    @id @default(uuid())
  title     String
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[] @relation("ArticleComment")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productId String?
  product   Product? @relation("ProductComment", fields: [productId], references: [id], onDelete: Cascade)

  articleId String?
  article   Article? @relation("ArticleComment", fields: [articleId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([articleId])
}
